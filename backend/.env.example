# Local PostgreSQL (use these OR DATABASE_URL — not both required)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flipkart

# Hosted PostgreSQL (Render, Railway, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/flipkart

PORT=5000
NODE_ENV=development
DB_SSL=false

# Required in production — use a long random string (32+ characters)
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated frontend URLs (required in production for security)
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:3000
